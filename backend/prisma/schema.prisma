generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model courses {
  id       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String    @db.VarChar(255)
  location String    @db.VarChar(255)
  players  players[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model game_players {
  game_id String  @db.Uuid
  user_id String  @db.Uuid
  games   games   @relation(fields: [game_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  players players @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([game_id, user_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model games {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String         @db.VarChar(255)
  source_url     String         @db.VarChar(255)
  min_players    Int?
  max_players    Int?
  game_image_url String?        @db.VarChar(255)
  game_players   game_players[]
  tournaments    tournaments[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model players {
  id                      String                    @id(map: "users_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String                    @db.VarChar(255)
  email                   String                    @unique(map: "users_email_key") @db.VarChar(255)
  password_hash           String                    @db.VarChar(255)
  avatar_url              String?                   @db.VarChar(255)
  member_since            DateTime                  @default(dbgenerated("CURRENT_DATE")) @db.Date
  course_id               String?                   @db.Uuid
  is_admin                Boolean                   @default(false)
  is_moderator            Boolean                   @default(false)
  game_players            game_players[]
  courses                 courses?                  @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "users_course_id_fkey")
  tournament_comments     tournament_comments[]
  tournament_participants tournament_participants[]
  tournament_results      tournament_results[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tournament_comments {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tournament_id String      @db.Uuid
  user_id       String      @db.Uuid
  body          String
  created_at    DateTime?   @default(now()) @db.Timestamp(6)
  tournaments   tournaments @relation(fields: [tournament_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  players       players     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tournament_participants {
  tournament_id String      @db.Uuid
  user_id       String      @db.Uuid
  tournaments   tournaments @relation(fields: [tournament_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  players       players     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([tournament_id, user_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tournament_results {
  tournament_id String      @db.Uuid
  user_id       String      @db.Uuid
  placement     Int         @db.SmallInt
  tournaments   tournaments @relation(fields: [tournament_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  players       players     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([tournament_id, user_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tournaments {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  game_id                 String                    @db.Uuid
  description             String
  start_date              DateTime?                 @db.Date
  end_date                DateTime?                 @db.Date
  tournament_image_url    String?                   @db.VarChar(255)
  tournament_comments     tournament_comments[]
  tournament_participants tournament_participants[]
  tournament_results      tournament_results[]
  games                   games                     @relation(fields: [game_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
